{
  "name": "posettakip",
  "private": true,
  "scripts": {
    "postinstall": "patch-package && node scripts/ensure-capacitor-vendor.cjs",
    "dev": "serve . -l 5173",
    "start": "serve . -l 5173",
    "copy:www": "node scripts/copy-www.cjs",
    "cap:sync": "npm run copy:www && npx cap sync android",
    "android:sync": "npm run cap:sync",
    "cap:open": "npx cap open android",
    "android:build": "npm run cap:sync && cd android && .\\gradlew.bat assembleDebug",
    "android:release": "npm run cap:sync && cd android && .\\gradlew.bat assembleRelease",
    "firebase:deploy-rules": "firebase deploy --only firestore:rules,storage --project emre-bebe-takip"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/share": "^6.0.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "firebase-tools": "^13.0.0",
    "patch-package": "^8.0.1",
    "serve": "^14.2.4"
  }
}
